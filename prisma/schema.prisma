generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  username      String    @unique
  email         String    @unique
  emailVerified DateTime?
  phone         String?   @unique
  displayName   String
  avatar        String?
  coverImage    String?
  bio           String?
  location      String?
  interests     String    @default("[]")
  primaryVehicleId   String?
  buildStreak        Int       @default(0)
  lastBuildActivityAt DateTime?
  maintenanceStreak  Int       @default(0)
  lastMaintenanceAt  DateTime?
  verifiedSeller     Boolean   @default(false)
  isVerifiedShop     Boolean   @default(false)
  isPro              Boolean   @default(false)
  proExpiresAt       DateTime?
  garageSlug         String?   @unique
  isAdmin            Boolean   @default(false)
  referredBy         String?
  referralCount      Int       @default(0)
  sceneTags          String    @default("[]")
  usernameChangedAt     DateTime?
  onboardingDismissedAt DateTime?
  createdAt     DateTime  @default(now())

  primaryVehicle Vehicle?  @relation("PrimaryVehicle", fields: [primaryVehicleId], references: [id], onDelete: SetNull)
  vehicles     Vehicle[]  @relation("UserVehicles")
  posts        Post[]
  pitUpdates   PitUpdate[]
  meetPins     MeetPin[]
  events       Event[]                   @relation("EventOrganizer")
  listings            MarketplaceListing[]
  purchasesAsBuyer    ListingTransaction[] @relation("ListingTransactionBuyer")
  salesAsSeller       ListingTransaction[] @relation("ListingTransactionSeller")
  maintenance  MaintenanceLog[]
  messages     Message[]
  participants ConversationParticipant[]
  eventRsvps   EventRsvp[]
  eventCheckIns EventCheckIn[]
  eventPhotos  EventPhoto[]
  convoyShares ConvoyShare[]
  likes        Like[]
  comments     Comment[]
  bookmarks    Bookmark[]
  following    Follow[]                  @relation("Follower")
  followers    Follow[]                  @relation("Following")
  followRequestsSent     FollowRequest[] @relation("FollowRequestsSent")
  followRequestsReceived FollowRequest[] @relation("FollowRequestsReceived")
  notificationsReceived Notification[] @relation("NotificationsReceived")
  notificationsSent     Notification[] @relation("NotificationsSent")
  settings     UserSettings?
  blocksInitiated UserBlock[] @relation("Blocker")
  blocksReceived  UserBlock[] @relation("Blocked")
  reportsFiled    UserReport[] @relation("Reporter")
  reportsReceived UserReport[] @relation("Reported")
  pushTokens      PushToken[]
  clubsOwned            Club[]              @relation("ClubOwner")
  clubMemberships       ClubMember[]
  clubJoinRequests      ClubJoinRequest[]
  clubChallengeEntries  ClubChallengeEntry[]
  clubChallengeWins     ClubChallenge[]     @relation("ClubChallengeWinner")
  clubDuesEntries       ClubDuesEntry[]     @relation("ClubDuesMember")
  clubDuesRecorded      ClubDuesEntry[]     @relation("ClubDuesRecorder")
  tradeOffersSent     TradeOffer[] @relation("TradeOfferFrom")
  tradeOffersReceived TradeOffer[] @relation("TradeOfferTo")
  savedSearches       SavedSearch[]
  hiddenPosts         HiddenPost[]
  postCollections     PostCollection[]
  mutedUsers          MutedUser[] @relation("MutingUser")
  mutedByUsers        MutedUser[] @relation("MutedByUser")
  shopRatings         ShopRating[]
  recallAcks          RecallAck[]
  manualGuideNotes    ManualGuideNote[]
  editPresets         EditPreset[]
  profileViews        ProfileView[]
  tagFollows          TagFollow[]
  crewList            CrewMember[] @relation("CrewOwner")
  crewMembership      CrewMember[] @relation("CrewMember")
  creatorLinks        CreatorLink[]

  @@index([primaryVehicleId])
}

model CrewMember {
  id         String   @id @default(cuid())
  userId     String
  crewUserId String
  createdAt  DateTime @default(now())

  user     User @relation("CrewOwner", fields: [userId], references: [id], onDelete: Cascade)
  crewUser User @relation("CrewMember", fields: [crewUserId], references: [id], onDelete: Cascade)

  @@unique([userId, crewUserId])
  @@index([userId])
  @@index([crewUserId])
}

model ProfileView {
  id        String   @id @default(cuid())
  profileId String
  viewerId  String?
  viewedAt  DateTime @default(now())

  profile User @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, viewedAt])
}

model CreatorLink {
  id        String   @id @default(cuid())
  userId    String
  title     String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
}

model Vehicle {
  id            String   @id @default(cuid())
  userId        String
  slug          String?  @unique
  year          Int
  make          String
  model         String
  trim          String?
  color         String?
  image         String?
  vin           String?
  story         String?
  fluidNotes    String?
  projectStatus       String?
  buildProgress       Int?
  installHours        Int?
  waitingOnParts      Boolean  @default(false)
  waitingOnPartsNote  String?
  forSale             Boolean  @default(false)
  createdAt           DateTime @default(now())

  user           User                 @relation("UserVehicles", fields: [userId], references: [id], onDelete: Cascade)
  primaryForUsers User[]              @relation("PrimaryVehicle")
  mods           Modification[]
  buildLogs      BuildLog[]
  maintenance    MaintenanceLog[]
  posts          Post[]
  listings       MarketplaceListing[]
  recallAcks     RecallAck[]
  clubProjects   ClubProject[]

  @@index([userId])
}

model Modification {
  id            String   @id @default(cuid())
  vehicleId     String
  name          String
  category      String
  status        String   @default("installed")
  installedAt   DateTime
  estimatedCost     Int?
  notes             String?
  videoUrl          String?
  affiliateUrl      String?
  partType          String   @default("aftermarket")
  marketplaceAlert  Boolean  @default(false)

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, status])
}

model BuildLog {
  id            String   @id @default(cuid())
  vehicleId     String
  title         String
  content       String
  milestoneType String   @default("update")
  image         String?
  images        String   @default("[]")
  dynoHp        Float?
  dynoTorque    Float?
  lapTime       String?
  trackName     String?
  createdAt     DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, createdAt])
}

model Post {
  id                String   @id @default(cuid())
  userId            String
  clubId            String?
  vehicleId         String?
  postType          String   @default("standard")
  image             String
  images            String   @default("[]")
  mediaType         String   @default("image")
  videoUrl          String?
  videoDuration     Int?
  videoPoster       String?
  videoChapters     String   @default("[]")
  beforeImage       String?
  afterImage        String?
  inspiredByPostId  String?
  collaborators     String   @default("[]")
  audioUrl          String?
  latitude          Float?
  longitude         Float?
  caption           String
  tags              String   @default("[]")
  status            String   @default("published")
  likes             Int      @default(0)
  commentCount      Int      @default(0)
  scheduledAt       DateTime?
  isSponsored       Boolean  @default(false)
  sponsorName       String?
  sponsorUrl        String?
  createdAt         DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  club       Club?    @relation(fields: [clubId], references: [id], onDelete: SetNull)
  vehicle    Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  inspiredBy Post?    @relation("PostInspiration", fields: [inspiredByPostId], references: [id], onDelete: SetNull)
  inspiredPosts Post[] @relation("PostInspiration")
  hiddenBy      HiddenPost[]
  collectionItems PostCollectionItem[]
  challengeEntries ClubChallengeEntry[]

  @@index([clubId, createdAt])
  @@index([vehicleId, createdAt])
  @@index([postType, createdAt])
  @@index([status, createdAt])
  @@index([status, scheduledAt])
  @@index([latitude, longitude])
  @@index([inspiredByPostId])
}

model PitUpdate {
  id           String   @id @default(cuid())
  userId       String
  image        String
  slides       String   @default("[]")
  caption      String
  visibility   String   @default("public")
  latitude     Float?
  longitude    Float?
  expiresAt    DateTime
  likes        Int      @default(0)
  commentCount Int      @default(0)
  highlights   String   @default("[]")
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, visibility])
  @@index([latitude, longitude])
}

model Event {
  id            String   @id @default(cuid())
  title         String
  description   String
  location      String
  city          String
  date          DateTime
  time          String
  organizerId   String
  clubId        String?
  attendeeCount Int      @default(0)
  maxAttendees  Int?
  tags          String   @default("[]")
  image         String?
  latitude      Float?
  longitude     Float?
  recurringRule String?
  routeJson     String   @default("[]")
  isOutdoor     Boolean  @default(true)
  boostedUntil  DateTime?
  ticketPrice   Int?
  ticketUrl     String?
  createdAt     DateTime @default(now())

  organizer User           @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  club      Club?          @relation(fields: [clubId], references: [id], onDelete: SetNull)
  rsvps     EventRsvp[]
  checkIns  EventCheckIn[]
  photos    EventPhoto[]
  convoyShares ConvoyShare[]
  parkingZones EventParkingZone[]
  conversations Conversation[]

  @@index([clubId])
  @@index([date])
}

model Club {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  city        String?
  image       String?
  coverImage  String?
  tags        String   @default("[]")
  ownerId     String
  memberCount       Int      @default(1)
  isPublic          Boolean  @default(true)
  requiresApproval  Boolean  @default(false)
  merchUrl          String?
  parentClubId      String?
  createdAt         DateTime @default(now())

  owner        User              @relation("ClubOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  parentClub   Club?             @relation("ClubChapters", fields: [parentClubId], references: [id], onDelete: SetNull)
  chapters     Club[]            @relation("ClubChapters")
  members      ClubMember[]
  joinRequests ClubJoinRequest[]
  events       Event[]
  posts        Post[]
  challenges   ClubChallenge[]
  projects      ClubProject[]
  duesEntries   ClubDuesEntry[]
  conversations Conversation[]

  @@index([parentClubId])
}

model ClubChallenge {
  id          String   @id @default(cuid())
  clubId      String
  title       String
  description String   @default("")
  type        String
  startsAt    DateTime
  endsAt      DateTime
  status      String   @default("active")
  winnerId    String?
  createdAt   DateTime @default(now())

  club    Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  winner  User?                @relation("ClubChallengeWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  entries ClubChallengeEntry[]

  @@index([clubId, status])
}

model ClubChallengeEntry {
  id          String   @id @default(cuid())
  challengeId String
  userId      String
  postId      String?
  createdAt   DateTime @default(now())

  challenge ClubChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post?         @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@unique([challengeId, userId])
  @@index([challengeId])
}

model ClubProject {
  id              String   @id @default(cuid())
  clubId          String
  vehicleId       String?
  title           String
  description     String   @default("")
  coverImage      String?
  contributorIds  String   @default("[]")
  status          String   @default("active")
  createdAt       DateTime @default(now())

  club    Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([clubId, status])
}

model ClubDuesEntry {
  id           String    @id @default(cuid())
  clubId       String
  userId       String
  amount       Float
  label        String
  paidAt       DateTime?
  recordedById String
  createdAt    DateTime  @default(now())

  club       Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user       User @relation("ClubDuesMember", fields: [userId], references: [id], onDelete: Cascade)
  recordedBy User @relation("ClubDuesRecorder", fields: [recordedById], references: [id], onDelete: Cascade)

  @@index([clubId, userId])
}

model ClubMember {
  id       String   @id @default(cuid())
  clubId   String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([userId])
}

model ClubJoinRequest {
  id         String    @id @default(cuid())
  clubId     String
  userId     String
  message    String?
  status     String    @default("pending")
  createdAt  DateTime  @default(now())
  reviewedAt DateTime?

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([clubId, status])
}

model MeetPin {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  latitude    Float
  longitude   Float
  address     String?
  pinType     String    @default("meet")
  expiresAt   DateTime?
  dynoHp      Float?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EventRsvp {
  id         String @id @default(cuid())
  eventId    String
  userId     String
  rsvpStatus String @default("going")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model MarketplaceListing {
  id            String   @id @default(cuid())
  sellerId      String
  vehicleId     String?
  modId         String?
  title         String
  description   String
  price         Int
  originalPrice Int?
  category      String
  condition     String
  image         String
  images        String   @default("[]")
  location      String
  fitmentTags   String   @default("[]")
  partNumber    String?
  tradeAccepted Boolean  @default(false)
  soldAt        DateTime?
  soldPrice     Float?
  latitude      Float?
  longitude     Float?
  isBundle      Boolean  @default(false)
  boostedUntil  DateTime?
  createdAt     DateTime @default(now())

  seller       User                 @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  vehicle      Vehicle?             @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  tradeOffers  TradeOffer[]
  transactions ListingTransaction[]

  @@index([sellerId, createdAt])
  @@index([vehicleId])
  @@index([category, createdAt])
  @@index([partNumber, soldAt])
  @@index([soldAt])
}

model ListingTransaction {
  id        String   @id @default(cuid())
  listingId String
  buyerId   String
  sellerId  String
  status    String   @default("requested")
  amount    Int
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer   User               @relation("ListingTransactionBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller  User               @relation("ListingTransactionSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([buyerId, status])
  @@index([sellerId, status])
}

model MaintenanceLog {
  id           String    @id @default(cuid())
  userId       String
  vehicleId    String
  title        String
  description  String
  mileage      Int
  cost         Int?
  category     String
  performedAt  DateTime
  receiptImage String?
  shopName        String?
  reminderAt      DateTime?
  nextDueDate     DateTime?
  nextDueMileage  Int?
  difficulty      Int?
  serviceType     String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([userId, performedAt])
  @@index([shopName])
}

model ShopRating {
  id        String   @id @default(cuid())
  userId    String
  shopName  String
  rating    Int
  review    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, shopName])
  @@index([shopName])
}

model RecallAck {
  id             String   @id @default(cuid())
  userId         String
  vehicleId      String
  campaignNumber String
  acknowledgedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([userId, vehicleId, campaignNumber])
  @@index([userId, vehicleId])
}

model ManualGuideNote {
  id           String   @id @default(cuid())
  userId       String
  vehicleMake  String
  vehicleModel String
  yearRange    String?
  section      String
  tip          String
  upvotes      Int      @default(0)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([vehicleMake, vehicleModel])
}

model ServiceManual {
  id           String @id @default(cuid())
  vehicleMake  String
  vehicleModel String
  yearRange    String
  title        String
  sections     String @default("[]")
}

model Conversation {
  id        String   @id @default(cuid())
  type      String   @default("dm")
  clubId    String?
  eventId   String?
  name      String?
  createdAt DateTime @default(now())

  club         Club?  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  event        Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  messages     Message[]
  participants ConversationParticipant[]

  @@index([type, clubId])
  @@index([type, eventId])
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  sentAt         DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Like {
  id           String   @id @default(cuid())
  userId       String
  targetType   String
  targetId     String
  reactionType String   @default("like")
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
}

model Comment {
  id              String   @id @default(cuid())
  userId          String
  targetType      String
  targetId        String
  parentId        String?
  quotedCommentId String?
  content         String
  createdAt       DateTime @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent        Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[] @relation("CommentReplies")
  quotedComment Comment?  @relation("QuotedComment", fields: [quotedCommentId], references: [id], onDelete: SetNull)
  quotedBy      Comment[] @relation("QuotedComment")

  @@index([targetType, targetId])
  @@index([parentId])
  @@index([quotedCommentId])
}

model MutedUser {
  id          String   @id @default(cuid())
  userId      String
  mutedUserId String
  createdAt   DateTime @default(now())

  user      User @relation("MutingUser", fields: [userId], references: [id], onDelete: Cascade)
  mutedUser User @relation("MutedByUser", fields: [mutedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, mutedUserId])
  @@index([userId])
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  targetType String
  targetId   String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([userId, createdAt])
}

model HiddenPost {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId, createdAt])
}

model PostCollection {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  user  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  items PostCollectionItem[]

  @@index([userId, createdAt])
}

model PostCollectionItem {
  id           String   @id @default(cuid())
  collectionId String
  postId       String
  createdAt    DateTime @default(now())

  collection PostCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  post       Post           @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([collectionId, postId])
  @@index([collectionId, createdAt])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

model FollowRequest {
  id          String    @id @default(cuid())
  requesterId String
  targetId    String
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  reviewedAt  DateTime?

  requester User @relation("FollowRequestsSent", fields: [requesterId], references: [id], onDelete: Cascade)
  target    User @relation("FollowRequestsReceived", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([requesterId, targetId])
  @@index([targetId, status])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  actorId    String
  type       String
  targetType String?
  targetId   String?
  groupKey   String?
  title      String
  body       String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  user  User @relation("NotificationsReceived", fields: [userId], references: [id], onDelete: Cascade)
  actor User @relation("NotificationsSent", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([userId, groupKey, createdAt])
}

model TagFollow {
  id        String   @id @default(cuid())
  userId    String
  tag       String
  tagType   String   @default("hashtag")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tag, tagType])
  @@index([tag, tagType])
}

model UserSettings {
  userId              String  @id
  emailNotifications  Boolean @default(true)
  pushNotifications   Boolean @default(true)
  activityAlerts      Boolean @default(true)
  messageAlerts       Boolean @default(true)
  meetReminders       Boolean @default(true)
  marketplaceAlerts   Boolean @default(true)
  weeklyDigest        Boolean @default(true)
  quietHoursStart     String?
  quietHoursEnd       String?
  nearYouRadius       Int     @default(50)
  profileVisibility   String  @default("public")
  showLocation        Boolean @default(true)
  showGarage          Boolean @default(true)
  allowMessages       String  @default("everyone")
  theme               String  @default("dark")
  sceneTags               String  @default("[]")
  alwaysWatermarkExports  Boolean @default(false)
  alwaysBlurPlates        Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EditPreset {
  id          String   @id @default(cuid())
  userId      String
  name        String
  adjustments String
  filterId    String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TradeOffer {
  id        String   @id @default(cuid())
  listingId String
  fromUserId String
  toUserId  String
  message   String?
  status    String   @default("pending")
  createdAt DateTime @default(now())

  listing  MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  fromUser User               @relation("TradeOfferFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User               @relation("TradeOfferTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([listingId, status])
  @@index([fromUserId, createdAt])
  @@index([toUserId, status])
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String
  query     String   @default("")
  filters   String   @default("{}")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model EventCheckIn {
  id          String   @id @default(cuid())
  eventId     String
  userId      String
  latitude    Float?
  longitude   Float?
  checkedInAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId, checkedInAt])
}

model EventPhoto {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  image     String
  caption   String?
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
  @@index([userId])
}

model ConvoyShare {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  latitude  Float
  longitude Float
  heading   Float?
  updatedAt DateTime @updatedAt
  expiresAt DateTime

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId, expiresAt])
}

model EventParkingZone {
  id        String @id @default(cuid())
  eventId   String
  label     String
  latitude  Float
  longitude Float
  color     String?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model UserReport {
  id           String   @id @default(cuid())
  reporterId   String
  reportedId   String
  reason       String
  details      String?
  status       String   @default("pending")
  appealNote   String?
  appealStatus String?
  createdAt    DateTime @default(now())

  reporter User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User @relation("Reported", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([reportedId, status])
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
