generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  username      String    @unique
  email         String    @unique
  emailVerified DateTime?
  displayName   String
  avatar        String?
  bio           String?
  location      String?
  interests     String    @default("[]")
  createdAt     DateTime  @default(now())

  vehicles     Vehicle[]
  posts        Post[]
  pitUpdates   PitUpdate[]
  meetPins     MeetPin[]
  events       Event[]                   @relation("EventOrganizer")
  listings     MarketplaceListing[]
  maintenance  MaintenanceLog[]
  messages     Message[]
  participants ConversationParticipant[]
  eventRsvps   EventRsvp[]
  likes        Like[]
  comments     Comment[]
  bookmarks    Bookmark[]
  following    Follow[]                  @relation("Follower")
  followers    Follow[]                  @relation("Following")
  notificationsReceived Notification[] @relation("NotificationsReceived")
  notificationsSent     Notification[] @relation("NotificationsSent")
  settings     UserSettings?
}

model Vehicle {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  make      String
  model     String
  trim      String?
  color     String?
  image     String?
  createdAt DateTime @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  mods        Modification[]
  buildLogs   BuildLog[]
  maintenance MaintenanceLog[]
}

model Modification {
  id          String   @id @default(cuid())
  vehicleId   String
  name        String
  category    String
  installedAt DateTime
  notes       String?

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model BuildLog {
  id        String   @id @default(cuid())
  vehicleId String
  title     String
  content   String
  image     String?
  images    String   @default("[]")
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model Post {
  id           String   @id @default(cuid())
  userId       String
  image        String
  images       String   @default("[]")
  caption      String
  tags         String   @default("[]")
  likes        Int      @default(0)
  commentCount Int      @default(0)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PitUpdate {
  id           String   @id @default(cuid())
  userId       String
  image        String
  caption      String
  expiresAt    DateTime
  likes        Int      @default(0)
  commentCount Int      @default(0)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Event {
  id            String   @id @default(cuid())
  title         String
  description   String
  location      String
  city          String
  date          DateTime
  time          String
  organizerId   String
  attendeeCount Int      @default(0)
  maxAttendees  Int?
  tags          String   @default("[]")
  image         String?
  latitude      Float?
  longitude     Float?
  createdAt     DateTime @default(now())

  organizer User        @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  rsvps     EventRsvp[]
}

model MeetPin {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  latitude    Float
  longitude   Float
  address     String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EventRsvp {
  id      String @id @default(cuid())
  eventId String
  userId  String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model MarketplaceListing {
  id            String   @id @default(cuid())
  sellerId      String
  title         String
  description   String
  price         Int
  category      String
  condition     String
  image         String
  images        String   @default("[]")
  location      String
  tradeAccepted Boolean  @default(false)
  createdAt     DateTime @default(now())

  seller User @relation(fields: [sellerId], references: [id], onDelete: Cascade)
}

model MaintenanceLog {
  id          String   @id @default(cuid())
  userId      String
  vehicleId   String
  title       String
  description String
  mileage     Int
  cost        Int?
  category    String
  performedAt DateTime

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model ServiceManual {
  id           String @id @default(cuid())
  vehicleMake  String
  vehicleModel String
  yearRange    String
  title        String
  sections     String @default("[]")
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  messages     Message[]
  participants ConversationParticipant[]
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  sentAt         DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Like {
  id         String   @id @default(cuid())
  userId     String
  targetType String
  targetId   String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
}

model Comment {
  id         String   @id @default(cuid())
  userId     String
  targetType String
  targetId   String
  parentId   String?
  content    String
  createdAt  DateTime @default(now())

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([targetType, targetId])
  @@index([parentId])
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  targetType String
  targetId   String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([userId, createdAt])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  actorId    String
  type       String
  targetType String?
  targetId   String?
  title      String
  body       String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  user  User @relation("NotificationsReceived", fields: [userId], references: [id], onDelete: Cascade)
  actor User @relation("NotificationsSent", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

model UserSettings {
  userId              String  @id
  emailNotifications  Boolean @default(true)
  pushNotifications   Boolean @default(true)
  activityAlerts      Boolean @default(true)
  messageAlerts       Boolean @default(true)
  meetReminders       Boolean @default(true)
  profileVisibility   String  @default("public")
  showLocation        Boolean @default(true)
  showGarage          Boolean @default(true)
  allowMessages       String  @default("everyone")
  theme               String  @default("dark")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
