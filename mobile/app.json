{
  "expo": {
    "name": "GearNet",
    "slug": "gearnet",
    "scheme": "gearnet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070b14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gearnet.app",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        },
        "NSLocalNetworkUsageDescription": "GearNet connects to your development computer on the local network to load data during testing."
      },
      "associatedDomains": ["applinks:gearnetapp.com", "applinks:www.gearnetapp.com"]
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#070b14"
      },
      "package": "com.gearnet.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "gearnetapp.com", "pathPrefix": "/" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiUrl": "https://gearnetapp.com",
      "eas": {
        "projectId": "e9ea28f1-9d31-446f-96bd-4a2baa3f8ec7"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4cc9f0"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow GearNet to use your location to drop meet pins on the map."
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow GearNet to access your photos for posts and garage uploads."
        }
      ]
    ],
    "owner": "primetrigger"
  }
}
