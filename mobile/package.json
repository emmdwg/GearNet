{
  "name": "gearnet-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --lan --clear --port 8084",
    "start:fast": "expo start --lan --port 8084",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build:ios": "cross-env EAS_NO_VCS=1 npx eas-cli build --platform ios --profile production",
    "submit:ios": "cross-env EAS_NO_VCS=1 npx eas-cli submit --platform ios --profile production",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.3.3",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.17.5",
    "@supabase/supabase-js": "^2.108.2",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.0",
    "expo-font": "~14.0.12",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-device": "~8.0.10",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.1.0",
    "cross-env": "^7.0.3",
    "typescript": "~5.9.2"
  },
  "private": true
}
