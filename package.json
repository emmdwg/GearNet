    "@sentry/nextjs": "^10.59.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo-server-sdk": "^3.14.0",
    "jose": "^6.2.3",
    "leaflet": "^1.9.4",
