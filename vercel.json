{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.gearnetapp.com" }],
      "destination": "https://gearnetapp.com/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/publish-scheduled-posts",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/meet-reminders",
      "schedule": "0 14 * * *"
    }
  ]
}
